<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude session data from cloud backup -->
        <exclude domain="file" path="datastore/fintech_session.preferences_pb"/>
        <exclude domain="sharedpref" path="app_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude session data from device-to-device transfer -->
        <exclude domain="file" path="datastore/fintech_session.preferences_pb"/>
        <exclude domain="sharedpref" path="app_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>
